# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/findmyride?retryWrites=true&w=majority

# Cron schedules (standard cron syntax)
# Default: ikman every 6 hours, riyasewana daily at 3am
IKMAN_CRON=0 */6 * * *
RIYASEWANA_CRON=0 3 * * *

# Scraper tuning
# Max listings per category per run (0 = unlimited, set a number for testing e.g. 50)
MAX_LISTINGS_PER_CATEGORY=0
# Concurrent browser tabs per scraper (raise carefully)
SCRAPER_CONCURRENCY=3

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Environment
NODE_ENV=development
